<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no, viewport-fit=cover">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="theme-color" content="#0a0a1a">
<link rel="manifest" href="manifest.json">
<title>Beat the Pipes</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;900&family=Orbitron:wght@700;900&display=swap" rel="stylesheet">
<style>
:root {
  --glass-bg: rgba(15, 15, 35, 0.85);
  --glass-border: rgba(255,255,255,0.08);
  --accent: #00e5ff;
  --accent2: #7c4dff;
  --accent3: #00e676;
  --danger: #ff1744;
  --text: #e0e0e0;
  --text-dim: #888;
  --radius: 16px;
  --grid: 8px;
}
* { margin: 0; padding: 0; box-sizing: border-box; }
html, body { width: 100%; height: 100%; overflow: hidden; background: #0a0a1a; touch-action: none; -webkit-touch-callout: none; -webkit-user-select: none; user-select: none; font-family: 'Inter', sans-serif; }
canvas { display: block; image-rendering: auto; position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); border-radius: 8px; box-shadow: 0 0 60px rgba(0,229,255,0.08); }

/* ── Shared Glass Panel ── */
.glass-overlay { display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.75); backdrop-filter:blur(8px); -webkit-backdrop-filter:blur(8px); z-index:300; flex-direction:column; align-items:center; justify-content:center; opacity:0; transition: opacity 0.3s ease; }
.glass-overlay.active { display:flex; opacity:1; }
.glass-panel { width:92%; max-width:360px; background:var(--glass-bg); border:1px solid var(--glass-border); border-radius:var(--radius); padding:28px 24px; color:var(--text); box-shadow:0 8px 40px rgba(0,0,0,0.6), inset 0 1px 0 rgba(255,255,255,0.05); transform:translateY(20px); transition: transform 0.3s ease; }
.glass-overlay.active .glass-panel { transform:translateY(0); }
.glass-panel h2 { text-align:center; margin-bottom:20px; font-family:'Orbitron', Arial,sans-serif; font-size:20px; background:linear-gradient(135deg, var(--accent), var(--accent2)); -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text; }

/* ── Settings ── */
.settings-row { display:flex; justify-content:space-between; align-items:center; padding:14px 0; border-bottom:1px solid rgba(255,255,255,0.06); }
.settings-row:last-child { border-bottom: none; }
.settings-label { font-size:14px; color:#bbb; font-weight:600; }
.slider-wrap { display:flex; align-items:center; gap:10px; }
.slider-wrap input[type=range] { -webkit-appearance:none; width:100px; height:4px; border-radius:2px; background:#333; outline:none; }
.slider-wrap input[type=range]::-webkit-slider-thumb { -webkit-appearance:none; width:18px; height:18px; border-radius:50%; background:var(--accent); cursor:pointer; box-shadow:0 0 8px rgba(0,229,255,0.4); }
.slider-val { font-size:12px; color:var(--accent); font-weight:700; min-width:28px; text-align:right; }

.toggle-btn { width:52px; height:28px; border-radius:14px; border:none; cursor:pointer; position:relative; transition:background 0.3s; background:#333; flex-shrink:0; }
.toggle-btn.on { background:var(--accent); }
.toggle-btn::after { content:''; position:absolute; width:22px; height:22px; border-radius:50%; background:#fff; top:3px; left:3px; transition:transform 0.3s cubic-bezier(0.4,0,0.2,1); }
.toggle-btn.on::after { transform:translateX(24px); }

.diff-btns { display:flex; gap:8px; flex-wrap:wrap; }
.diff-btn { padding:8px 16px; border-radius:20px; border:2px solid #333; background:transparent; color:#888; font-size:13px; font-weight:700; cursor:pointer; transition:all 0.25s ease; font-family:'Inter',sans-serif; }
.diff-btn.active { border-color:var(--accent); color:var(--accent); background:rgba(0,229,255,0.1); box-shadow:0 0 12px rgba(0,229,255,0.15); }
.diff-btn:hover { border-color:#666; color:#ccc; }
.settings-close { display:block; width:100%; margin-top:24px; padding:14px; border-radius:12px; border:none; background:linear-gradient(135deg, var(--accent), var(--accent2)); color:#fff; font-size:16px; font-weight:700; cursor:pointer; font-family:'Inter',sans-serif; letter-spacing:0.5px; transition: transform 0.2s, box-shadow 0.2s; }
.settings-close:active { transform:scale(0.97); }
.settings-close:hover { box-shadow:0 4px 20px rgba(0,229,255,0.3); }

/* Settings gear */
#settingsGear { position:fixed; top:12px; right:12px; z-index:90; background:var(--glass-bg); border:1.5px solid var(--glass-border); color:var(--accent); font-size:22px; width:44px; height:44px; border-radius:50%; cursor:pointer; box-shadow:0 2px 12px rgba(0,0,0,0.4); display:flex; align-items:center; justify-content:center; transition:transform 0.3s cubic-bezier(0.4,0,0.2,1), box-shadow 0.3s; backdrop-filter:blur(8px); -webkit-backdrop-filter:blur(8px); }
#settingsGear:hover { transform:scale(1.1) rotate(30deg); box-shadow:0 0 20px rgba(0,229,255,0.2); }

/* ── Tutorial Overlay ── */
#tutorialOverlay { display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.92); z-index:400; flex-direction:column; align-items:center; justify-content:center; padding:32px; }
#tutorialOverlay.active { display:flex; }
.tutorial-card { width:100%; max-width:320px; text-align:center; }
.tutorial-icon { font-size:64px; margin-bottom:16px; animation:float 2s ease-in-out infinite; }
.tutorial-title { font-family:'Orbitron', Arial,sans-serif; font-size:24px; color:#fff; margin-bottom:12px; }
.tutorial-desc { font-size:15px; color:#aaa; line-height:1.6; margin-bottom:24px; }
.tutorial-dots { display:flex; gap:8px; justify-content:center; margin-bottom:24px; }
.tutorial-dot { width:8px; height:8px; border-radius:50%; background:#333; transition:all 0.3s; }
.tutorial-dot.active { background:var(--accent); width:24px; border-radius:4px; box-shadow:0 0 8px rgba(0,229,255,0.4); }
.tutorial-btn { padding:14px 40px; border-radius:25px; border:none; background:linear-gradient(135deg, var(--accent), var(--accent2)); color:#fff; font-size:16px; font-weight:700; cursor:pointer; font-family:'Inter',sans-serif; transition:transform 0.2s; }
.tutorial-btn:active { transform:scale(0.95); }

@keyframes float { 0%,100% { transform:translateY(0); } 50% { transform:translateY(-8px); } }

/* ── Ad Overlay ── */
#adOverlay { display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.9); z-index:200; flex-direction:column; align-items:center; justify-content:center; }
#adOverlay.active { display:flex; }
#adContainer { width:90%; max-width:400px; background:var(--glass-bg); border:1px solid var(--glass-border); border-radius:var(--radius); padding:30px; text-align:center; color:#fff; }
#adTimer { font-size:14px; color:#aaa; margin-top:10px; }
#adRewardBtn { background:linear-gradient(135deg, var(--accent3), #00c853); color:#fff; border:none; padding:14px 28px; border-radius:25px; font-size:18px; font-weight:bold; cursor:pointer; margin-top:15px; box-shadow:0 4px 15px rgba(0,230,118,0.3); transition:transform 0.2s; font-family:'Inter',sans-serif; }
#adRewardBtn:disabled { background:#333; cursor:not-allowed; box-shadow:none; }
#adRewardBtn:not(:disabled):active { transform:scale(0.96); }
#skipAdBtn { background:transparent; color:#666; border:1px solid #444; padding:8px 20px; border-radius:15px; font-size:13px; cursor:pointer; margin-top:12px; font-family:'Inter',sans-serif; }

/* ── Install Button ── */
#installBtn { display:none; position:fixed; bottom:24px; left:50%; transform:translateX(-50%); background:linear-gradient(135deg, var(--accent), var(--accent2)); color:#fff; border:none; padding:12px 28px; border-radius:25px; font-size:15px; font-weight:700; z-index:100; box-shadow:0 4px 20px rgba(0,229,255,0.3); font-family:'Inter',sans-serif; letter-spacing:0.5px; transition:transform 0.2s; }
#installBtn:active { transform:translateX(-50%) scale(0.96); }

/* ── Score Popup ── */
.score-popup { position:fixed; pointer-events:none; z-index:150; font-family:'Orbitron', Arial,sans-serif; font-weight:900; font-size:28px; color:var(--accent); text-shadow:0 0 12px rgba(0,229,255,0.5); animation:scoreUp 0.8s ease-out forwards; }
@keyframes scoreUp { 0% { opacity:1; transform:translateY(0) scale(1); } 100% { opacity:0; transform:translateY(-60px) scale(1.3); } }

/* ── Combo Toast ── */
.combo-toast { position:fixed; top:60px; left:50%; transform:translateX(-50%); z-index:150; background:linear-gradient(135deg, rgba(0,229,255,0.2), rgba(124,77,255,0.2)); border:1px solid rgba(0,229,255,0.3); padding:8px 20px; border-radius:20px; font-family:'Orbitron', Arial,sans-serif; font-size:14px; font-weight:700; color:var(--accent); backdrop-filter:blur(8px); -webkit-backdrop-filter:blur(8px); animation:comboIn 0.3s ease-out, comboOut 0.3s 1.2s ease-in forwards; white-space:nowrap; }
@keyframes comboIn { 0% { opacity:0; transform:translateX(-50%) translateY(-10px) scale(0.8); } 100% { opacity:1; transform:translateX(-50%) translateY(0) scale(1); } }
@keyframes comboOut { 0% { opacity:1; } 100% { opacity:0; transform:translateX(-50%) translateY(-10px); } }

/* ── Tip Jar ── */
#tipJar { position:fixed; bottom:72px; right:12px; z-index:90; }
#tipJar a { display:block; background:linear-gradient(135deg, #ff6b6b, #ee5a24); color:#fff; text-decoration:none; padding:8px 14px; border-radius:20px; font-size:13px; font-weight:700; box-shadow:0 3px 12px rgba(255,107,107,0.3); font-family:'Inter',sans-serif; transition:transform 0.2s; }
#tipJar a:active { transform:scale(0.95); }

/* ── Ad Banner ── */
#adsense-banner { position:fixed; bottom:0; left:0; width:100%; background:var(--glass-bg); text-align:center; padding:6px 0; z-index:80; border-top:1px solid var(--glass-border); }

/* Store button */
#storeBtn { position:fixed; top:12px; left:12px; z-index:90; background:var(--glass-bg); border:1.5px solid var(--glass-border); color:#ffab00; font-size:20px; width:44px; height:44px; border-radius:50%; cursor:pointer; box-shadow:0 2px 12px rgba(0,0,0,0.4); display:flex; align-items:center; justify-content:center; transition:transform 0.3s cubic-bezier(0.4,0,0.2,1), box-shadow 0.3s; backdrop-filter:blur(8px); -webkit-backdrop-filter:blur(8px); }
#storeBtn:hover { transform:scale(1.1) rotate(-10deg); box-shadow:0 0 20px rgba(255,171,0,0.2); }

/* Store Overlay */
#storeOverlay .glass-panel { max-height:85vh; overflow-y:auto; }
#storeOverlay .glass-panel::-webkit-scrollbar { width:4px; }
#storeOverlay .glass-panel::-webkit-scrollbar-thumb { background:var(--accent); border-radius:2px; }
.store-coins { text-align:center; font-size:18px; font-weight:700; color:#ffab00; margin-bottom:16px; font-family:'Orbitron', Arial,sans-serif; }
.store-item { display:flex; align-items:center; gap:12px; padding:12px; margin-bottom:10px; background:rgba(255,255,255,0.04); border:1px solid rgba(255,255,255,0.06); border-radius:12px; transition: border-color 0.2s; }
.store-item:hover { border-color:rgba(255,255,255,0.12); }
.store-item-icon { font-size:28px; width:44px; text-align:center; flex-shrink:0; }
.store-item-info { flex:1; }
.store-item-name { font-size:14px; font-weight:700; color:#eee; }
.store-item-desc { font-size:11px; color:#888; margin-top:2px; }
.store-item-price { font-size:12px; color:#ffab00; font-weight:600; margin-top:3px; }
.store-owned { font-size:11px; color:var(--accent3); font-weight:600; }
.store-buy-btn { padding:8px 16px; border-radius:20px; border:none; background:linear-gradient(135deg, #ffab00, #ff6d00); color:#fff; font-size:12px; font-weight:700; cursor:pointer; font-family:'Inter',sans-serif; transition:transform 0.15s, opacity 0.15s; flex-shrink:0; }
.store-buy-btn:active { transform:scale(0.95); }
.store-buy-btn:disabled { background:#333; color:#666; cursor:not-allowed; }
.store-close { display:block; width:100%; margin-top:16px; padding:14px; border-radius:12px; border:none; background:linear-gradient(135deg, var(--accent), var(--accent2)); color:#fff; font-size:16px; font-weight:700; cursor:pointer; font-family:'Inter',sans-serif; transition:transform 0.2s; }
.store-close:active { transform:scale(0.97); }

/* Power-up Toast */
.powerup-toast { position:fixed; top:50px; left:50%; transform:translateX(-50%); z-index:160; background:linear-gradient(135deg, rgba(0,229,255,0.25), rgba(124,77,255,0.25)); border:1px solid rgba(0,229,255,0.4); padding:8px 20px; border-radius:20px; font-family:'Orbitron', Arial,sans-serif; font-size:13px; font-weight:700; color:#fff; backdrop-filter:blur(8px); -webkit-backdrop-filter:blur(8px); animation:comboIn 0.3s ease-out, comboOut 0.3s 1.2s ease-in forwards; white-space:nowrap; }
.ach-toast{position:fixed;top:100px;left:50%;transform:translateX(-50%);z-index:160;background:linear-gradient(135deg,rgba(255,171,0,0.25),rgba(255,109,0,0.25));border:1px solid rgba(255,171,0,0.4);padding:10px 20px;border-radius:16px;font-size:13px;font-weight:700;color:#ffab00;backdrop-filter:blur(8px);animation:comboIn 0.3s ease-out,comboOut 0.3s 2s ease-in forwards;white-space:nowrap;text-align:center;}
.ach-item{display:flex;align-items:center;gap:10px;padding:10px;margin-bottom:8px;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.06);border-radius:10px;}
.ach-item.unlocked{border-color:rgba(255,171,0,0.3);background:rgba(255,171,0,0.06);}
.ach-item.locked .ach-icon{filter:grayscale(1);opacity:0.4;}
.ach-name{font-size:13px;font-weight:700;color:#eee;}
.ach-item.locked .ach-name{color:#555;}
.ach-desc{font-size:10px;color:#888;margin-top:1px;}
.stat-row{display:flex;justify-content:space-between;padding:10px 0;border-bottom:1px solid rgba(255,255,255,0.05);}
.stat-label{font-size:13px;color:#aaa;}
.stat-val{font-size:13px;font-weight:700;color:var(--accent);}
.challenge-item{padding:10px 12px;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.06);border-radius:10px;margin-bottom:8px;}
.challenge-item.done{border-color:rgba(0,230,118,0.3);background:rgba(0,230,118,0.06);}
.challenge-text{font-size:13px;color:#eee;font-weight:600;}
.challenge-item.done .challenge-text{color:#00e677;}
.challenge-reward{font-size:11px;color:#ffab00;margin-top:3px;}
.menu-icons{display:flex;gap:10px;justify-content:center;margin-top:8px;}
.menu-icon-btn{width:40px;height:40px;border-radius:50%;border:1.5px solid rgba(255,255,255,0.08);background:rgba(15,15,35,0.85);color:#fff;font-size:18px;cursor:pointer;display:flex;align-items:center;justify-content:center;position:relative;}
.menu-badge{position:absolute;top:-4px;right:-4px;background:#ff1744;color:#fff;font-size:9px;font-weight:700;min-width:16px;height:16px;border-radius:8px;display:flex;align-items:center;justify-content:center;padding:0 3px;}
.theme-btn{padding:8px 12px;border-radius:20px;border:2px solid #333;background:transparent;color:#888;font-size:12px;font-weight:700;cursor:pointer;font-family:'Inter',sans-serif;}
.theme-btn.active{border-color:#7c4dff;color:#7c4dff;background:rgba(124,77,255,0.1);}
.ach-toast{position:fixed;top:100px;left:50%;transform:translateX(-50%);z-index:160;background:linear-gradient(135deg,rgba(255,171,0,0.25),rgba(255,109,0,0.25));border:1px solid rgba(255,171,0,0.4);padding:10px 20px;border-radius:16px;font-size:13px;font-weight:700;color:#ffab00;backdrop-filter:blur(8px);animation:comboIn 0.3s ease-out,comboOut 0.3s 2s ease-in forwards;white-space:nowrap;text-align:center;}
.ach-item{display:flex;align-items:center;gap:10px;padding:10px;margin-bottom:8px;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.06);border-radius:10px;}
.ach-item.unlocked{border-color:rgba(255,171,0,0.3);background:rgba(255,171,0,0.06);}
.ach-item.locked .ach-icon{filter:grayscale(1);opacity:0.4;}
.ach-name{font-size:13px;font-weight:700;color:#eee;}
.ach-item.locked .ach-name{color:#555;}
.ach-desc{font-size:10px;color:#888;margin-top:1px;}
.stat-row{display:flex;justify-content:space-between;padding:10px 0;border-bottom:1px solid rgba(255,255,255,0.05);}
.stat-label{font-size:13px;color:#aaa;}
.stat-val{font-size:13px;font-weight:700;color:var(--accent);}
.challenge-item{padding:10px 12px;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.06);border-radius:10px;margin-bottom:8px;}
.challenge-item.done{border-color:rgba(0,230,118,0.3);background:rgba(0,230,118,0.06);}
.challenge-text{font-size:13px;color:#eee;font-weight:600;}
.challenge-item.done .challenge-text{color:#00e677;}
.challenge-reward{font-size:11px;color:#ffab00;margin-top:3px;}
.menu-icons{display:flex;gap:10px;justify-content:center;margin-top:8px;}
.menu-icon-btn{width:40px;height:40px;border-radius:50%;border:1.5px solid rgba(255,255,255,0.08);background:rgba(15,15,35,0.85);color:#fff;font-size:18px;cursor:pointer;display:flex;align-items:center;justify-content:center;position:relative;}
.menu-badge{position:absolute;top:-4px;right:-4px;background:#ff1744;color:#fff;font-size:9px;font-weight:700;min-width:16px;height:16px;border-radius:8px;display:flex;align-items:center;justify-content:center;padding:0 3px;}
.theme-btn{padding:8px 12px;border-radius:20px;border:2px solid #333;background:transparent;color:#888;font-size:12px;font-weight:700;cursor:pointer;font-family:'Inter',sans-serif;}
.theme-btn.active{border-color:#7c4dff;color:#7c4dff;background:rgba(124,77,255,0.1);}

</style>
</head>
<body>
<canvas id="game"></canvas>
<button id="installBtn">📲 Install App</button>
<button id="settingsGear" title="Settings">⚙</button>
<button id="storeBtn" title="Store">🛍️</button>
<button id="achBtn" title="Achievements" style="position:fixed;top:12px;left:60px;z-index:90;background:rgba(15,15,35,0.85);border:1.5px solid rgba(255,255,255,0.08);color:#ffab00;font-size:20px;width:44px;height:44px;border-radius:50%;cursor:pointer;display:flex;align-items:center;justify-content:center;backdrop-filter:blur(8px);">🏆</button>
<button id="challengesBtn" title="Daily Challenges" style="position:fixed;top:12px;left:108px;z-index:90;background:rgba(15,15,35,0.85);border:1.5px solid rgba(255,255,255,0.08);color:#00e676;font-size:20px;width:44px;height:44px;border-radius:50%;cursor:pointer;display:flex;align-items:center;justify-content:center;backdrop-filter:blur(8px);">📅</button>
<button id="statsBtn" title="Statistics" style="position:fixed;top:12px;left:156px;z-index:90;background:rgba(15,15,35,0.85);border:1.5px solid rgba(255,255,255,0.08);color:#00e5ff;font-size:20px;width:44px;height:44px;border-radius:50%;cursor:pointer;display:flex;align-items:center;justify-content:center;backdrop-filter:blur(8px);">📊</button>


<!-- Tutorial Overlay -->
<div id="tutorialOverlay">
  <div class="tutorial-card">
    <div class="tutorial-icon" id="tutIcon">🎵</div>
    <div class="tutorial-title" id="tutTitle">BEAT THE PIPES</div>
    <div class="tutorial-desc" id="tutDesc">Tap to fly your bird through the pipes. Hit the beat, chain combos, and climb the leaderboard!</div>
    <div class="tutorial-dots">
      <div class="tutorial-dot active" id="dot0"></div>
      <div class="tutorial-dot" id="dot1"></div>
      <div class="tutorial-dot" id="dot2"></div>
    </div>
    <button class="tutorial-btn" id="tutBtn">Next →</button>
  </div>
</div>

<!-- Settings Overlay -->
<div id="settingsOverlay" class="glass-overlay">
  <div class="glass-panel">
    <h2>⚙ SETTINGS</h2>
    <div class="settings-row">
      <span class="settings-label">🎵 Music</span>
      <button id="musicToggle" class="toggle-btn on" onclick="toggleMusic()"></button>
    </div>
    <div class="settings-row">
      <span class="settings-label">🔊 SFX Volume</span>
      <div class="slider-wrap">
        <input type="range" id="sfxSlider" min="0" max="100" value="80" oninput="setSFXVolume(this.value)">
        <span class="slider-val" id="sfxVal">80%</span>
      </div>
    </div>
    <d
